    <!-- Firebase Scripts -->
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
    
    <script>
    // Firebase config
    const firebaseConfig = {
      apiKey: "AIzaSyBlpLfL6ProXUrqhr9FGET7ACfPOKBudSw",
      authDomain: "gen-lang-client-0007945213.firebaseapp.com",
      projectId: "gen-lang-client-0007945213"
    };
    
    firebase.initializeApp(firebaseConfig);
    const auth = firebase.auth();

    // Protect this page - redirect to login if not signed in
    auth.onAuthStateChanged((user) => {
      if (!user) {
        console.log('❌ Not logged in, redirecting to login page');
        window.location.href = 'login.html';
      } else {
        console.log('✅ User authenticated:', user.email);
        document.getElementById('userName').textContent = user.displayName || user.email;
      }
    });

    // Logout function
    function logout() {
      if (confirm('Are you sure you want to logout?')) {
        auth.signOut().then(() => {
          console.log('✅ Logged out successfully');
          window.location.href = 'login.html';
        }).catch((error) => {
          console.error('Logout error:', error);
          alert('Logout failed: ' + error.message);
        });
      }
    }
    </script>
<script>if(!localStorage.getItem("bstm_token")){localStorage.setItem("bstm_token","temp");}</script>
<script>localStorage.setItem("bstm_token", localStorage.getItem("bstm_token") || "locked");</script>
</body>
</html>

<script>
const API_URL = 'http://localhost:3000';

// Soft auth check - delay to prevent bounce
setTimeout(() => {
    const token = localStorage.getItem('bstm_token');
    const userStr = localStorage.getItem('bstm_user');
    
    if (!token || !userStr) {
        alert('Please log in first');
        window.location.href = 'login.html';
        return;
    }

    const user = JSON.parse(userStr);
    
    // Update UI with user data
    document.getElementById('userName').textContent = user.name || user.email.split('@')[0];
    document.getElementById('userEmail').textContent = user.email;
    document.getElementById('welcomeName').textContent = user.name || user.email.split('@')[0];
    document.getElementById('referralCode').textContent = user.referral_code || 'BSTM-XXXXX';

    // Load REAL THB balance from server
    loadRealBalance(token);

}, 2000); // 2-second delay prevents bounce

async function loadRealBalance(token) {
    try {
        const response = await fetch(API_URL + '/wallet/balance', {
            headers: {
                'Authorization': 'Bearer ' + token
            }
        });

        if (response.ok) {
            const data = await response.json();
            console.log('💰 Real balance:', data.balance);
            
            // Update THB balance with REAL value
            const balanceEl = document.getElementById('thbBalance');
            if (balanceEl) {
                balanceEl.textContent = data.balance.toFixed(2);
            }
        } else {
            console.warn('⚠️ Balance fetch failed, using cached value');
            const user = JSON.parse(localStorage.getItem('bstm_user'));
            const balanceEl = document.getElementById('thbBalance');
            if (balanceEl) {
                balanceEl.textContent = (user.thb_balance || 50).toFixed(2);
            }
        }
    } catch (error) {
        console.error('❌ Balance error:', error);
    }
}

// Logout function
function logout() {
    if (!confirm('Logout?')) return;
    
    localStorage.removeItem('bstm_token');
    localStorage.removeItem('bstm_user');
    localStorage.removeItem('bstm_role');
    localStorage.removeItem('bstm_authenticated');
    
    window.location.href = 'login.html';
}

// Wallet function
function openWallet() {
    window.location.href = 'thb-wallet.html';
}

// Share referral
function shareReferral() {
    const user = JSON.parse(localStorage.getItem('bstm_user'));
    const code = user.referral_code;
    const link = 'https://bstm.bw/ref/' + code;
    
    if (navigator.share) {
        navigator.share({
            title: 'Join BSTM',
            text: 'Use code ' + code + ' for 50 THB bonus!',
            url: link
        });
    } else {
        navigator.clipboard.writeText(link);
        alert('Link copied!');
    }
}
</script>
